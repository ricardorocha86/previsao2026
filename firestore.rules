rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    function validEmail(email) {
      return email is string
        && email.size() <= 254
        && email == email.trim()
        && email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    function validRequiredString(value, minSize, maxSize) {
      return value is string
        && value == value.trim()
        && value.size() >= minSize
        && value.size() <= maxSize;
    }

    function validOptionalString(value, maxSize) {
      return value is string
        && value == value.trim()
        && value.size() <= maxSize;
    }

    function validParticipant(participant) {
      return participant is map
        && participant.keys().hasAll([
          'name',
          'email',
          'expertiseLevel',
          'footballFollowFrequency',
          'cupPoolExperience',
          'favoriteTeam'
        ])
        && participant.keys().hasOnly([
          'name',
          'email',
          'expertiseLevel',
          'footballFollowFrequency',
          'cupPoolExperience',
          'favoriteTeam'
        ])
        && validRequiredString(participant.name, 2, 120)
        && validEmail(participant.email)
        && participant.expertiseLevel in ['none', 'little', 'regular', 'expert']
        && participant.footballFollowFrequency in ['never', 'rarely', 'sometimes', 'weekly']
        && participant.cupPoolExperience in ['never', 'once', 'some', 'always']
        && validOptionalString(participant.favoriteTeam, 80);
    }

    function validFillMetadata(fillMetadata) {
      return fillMetadata is map
        && fillMetadata.keys().hasAll([
          'usedRandomGroupFill',
          'randomGroupMatchCount'
        ])
        && fillMetadata.keys().hasOnly([
          'usedRandomGroupFill',
          'randomGroupMatchCount'
        ])
        && fillMetadata.usedRandomGroupFill is bool
        && fillMetadata.randomGroupMatchCount is int
        && fillMetadata.randomGroupMatchCount >= 0
        && fillMetadata.randomGroupMatchCount <= 72
        && fillMetadata.usedRandomGroupFill == (fillMetadata.randomGroupMatchCount > 0);
    }

    function validSubmissionId(submissionId) {
      return submissionId is string
        && submissionId.size() <= 254
        && submissionId == submissionId.lower()
        && submissionId.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    function validSubmission(submissionId) {
      return request.resource.data is map
        && request.resource.data.keys().hasAll([
          'participant',
          'submittedAt',
          'champion',
          'fillMetadata',
          'predictions'
        ])
        && request.resource.data.keys().hasOnly([
          'participant',
          'submittedAt',
          'champion',
          'fillMetadata',
          'predictions'
        ])
        && validSubmissionId(submissionId)
        && validParticipant(request.resource.data.participant)
        && validFillMetadata(request.resource.data.fillMetadata)
        && submissionId == request.resource.data.participant.email.lower()
        && request.resource.data.submittedAt is string
        && request.resource.data.submittedAt.matches('^\\d{4}-\\d{2}-\\d{2}T.*Z$')
        && validRequiredString(request.resource.data.champion, 1, 80)
        && request.resource.data.predictions is list
        && request.resource.data.predictions.size() == 104;
    }

    match /bolao2026/{submissionId} {
      allow read: if isAdmin();
      allow create: if validSubmission(submissionId);
      allow update, delete: if false;
    }

    match /adminUsers/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
